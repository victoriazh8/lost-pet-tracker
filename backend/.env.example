# Copy this file to .env and fill in your values
# Never commit .env to git

ANTHROPIC_API_KEY=your_api_key_here

# Set to true to enable AI-powered name/description extraction (costs tokens)
# Set to false to use rule-based extraction only (free, works without API key)
USE_AI=false

# Production only: restrict CORS to your Vercel frontend URL
# Leave blank locally (allows all origins during development)
# ALLOWED_ORIGIN=https://your-app.vercel.app

# Production only: path to persistent volume (set automatically by fly.toml env section)
# DATA_DIR=/data
